{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "cleanUrls": true,
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm start",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/api/index.js?path=:path*"
    }
  ]
}
