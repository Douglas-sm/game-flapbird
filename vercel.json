{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "{index.html,style.css,js/**,assets/**,dist/**}"
    }
  },
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/api/index.js?path=:path*"
    }
  ]
}